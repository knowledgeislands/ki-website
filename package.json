{
  "name": "@knowledgeislands/ki-website",
  "description": "Public-facing portal for Knowledge Islands — shares project knowledge and links out to key resources.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/ki-website/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@biomejs/biome": "2.5.4",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.5",
    "syncpack": "^15.3.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/ki-website#readme",
  "keywords": [
    "arcadia",
    "eleventy",
    "knowledge-islands",
    "tailwindcss",
    "website"
  ],
  "license": "UNLICENSED",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/ki-website.git"
  },
  "scripts": {
    "clean": "rm -rf {node_modules,site/dist}",
    "ki:audit": "bun .ki-meta/bin/aggregate.ts audit",
    "ki:authoring:audit": "bun .ki-meta/checkers/ki-authoring/scripts/audit.ts .",
    "ki:authoring:conform": "bun .ki-meta/checkers/ki-authoring/scripts/conform.ts .",
    "ki:conform": "bun .ki-meta/bin/aggregate.ts conform",
    "ki:decision-records:audit": "bun .ki-meta/checkers/ki-decision-records/scripts/audit.ts .",
    "ki:decision-records:conform": "bun .ki-meta/checkers/ki-decision-records/scripts/conform.ts .",
    "ki:educate": "bun .ki-meta/bin/aggregate.ts educate",
    "ki:engineering:audit": "bun .ki-meta/checkers/ki-engineering/scripts/audit.ts .",
    "ki:engineering:conform": "bun .ki-meta/checkers/ki-engineering/scripts/conform.ts .",
    "ki:help": "bun .ki-meta/bin/aggregate.ts help",
    "ki:hosting-cloudflare:audit": "bun .claude/skills/ki-hosting-cloudflare/scripts/audit-cloudflare-hosting.ts .",
    "ki:init": "bun scripts/ki/aggregate.ts init",
    "ki:project-roadmap:audit": "bun .ki-meta/checkers/ki-project-roadmap/scripts/audit.ts .",
    "ki:project-roadmap:conform": "bun .ki-meta/checkers/ki-project-roadmap/scripts/conform.ts .",
    "ki:repo:audit": "bun .ki-meta/checkers/ki-repo/scripts/audit.ts .",
    "ki:repo:conform": "bun .ki-meta/checkers/ki-repo/scripts/conform.ts .",
    "ki:site:build": "cd site && node --experimental-strip-types ../node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts",
    "ki:site:clean": "rm -rf site/dist site/.wrangler",
    "ki:site:deploy": "cd site && bunx wrangler deploy",
    "ki:site:dev": "concurrently --names css,11ty --prefix-colors cyan,yellow \"bun run ki:site:dev:css\" \"bun run ki:site:dev:serve\"",
    "ki:site:dev:css": "cd site && bunx tailwindcss -i src/assets/css/main.css -o dist/assets/css/main.css --watch",
    "ki:site:dev:serve": "cd site && node --experimental-strip-types ../node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts --serve --port 3000",
    "ki:site:preview": "bun run ki:site:build && cd site && bunx wrangler dev",
    "ki:site:upload": "cd site && bunx wrangler versions upload",
    "ki:skills:link:project": "bun $HOME/.claude/skills/knowledgeislands-bootstrap/scripts/link-skills.ts",
    "ki:tokenomics:audit": "bun .ki-meta/checkers/ki-tokenomics/scripts/audit.ts .",
    "ki:tokenomics:conform": "bun .ki-meta/checkers/ki-tokenomics/scripts/conform.ts .",
    "ki:website-cloudflare:audit": "bun .ki-meta/checkers/ki-website-cloudflare/scripts/audit.ts .",
    "ki:website-cloudflare:conform": "bun .ki-meta/checkers/ki-website-cloudflare/scripts/conform.ts .",
    "ki:website:audit": "bun .ki-meta/checkers/ki-website/scripts/audit.ts .",
    "ki:website:conform": "bun .ki-meta/checkers/ki-website/scripts/conform.ts .",
    "ki:websites-11ty:audit": "bun .claude/skills/ki-websites-11ty/scripts/audit-websites.ts .",
    "prepare": "husky"
  },
  "type": "module",
  "workspaces": [
    "site"
  ]
}
