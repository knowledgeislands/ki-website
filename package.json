{
  "name": "@knowledgeislands/arcadia-website",
  "description": "The public facing portal of Arcadia, designed to share knowledge outward and provide access to key resources from the principal island",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bugs": {
    "url": "https://github.com/knowledgeislands/arcadia-website/issues"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@biomejs/biome": "2.5.0",
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "json5": "^2.2.3",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "syncpack": "^15.3.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.102.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://github.com/knowledgeislands/arcadia-website#readme",
  "keywords": [
    "arcadia",
    "eleventy",
    "knowledge-islands",
    "tailwindcss",
    "website"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,mjs,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/arcadia-website.git"
  },
  "scripts": {
    "build": "node --experimental-strip-types node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts",
    "clean": "rm -rf {dist,node_modules}",
    "deps:missing": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.missing | keys | .[]' | xargs bun add -D",
    "deps:unused": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.devDependencies[]' | xargs bun remove",
    "deps:update": "bun update --latest",
    "dev": "concurrently --names css,11ty --prefix-colors cyan,yellow \"bun run dev:css\" \"bun run dev:serve\"",
    "dev:css": "bunx tailwindcss -i src/assets/css/main.css -o dist/assets/css/main.css --watch",
    "dev:serve": "node --experimental-strip-types node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts --serve --port 3000",
    "lint:check": "bunx @biomejs/biome check",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe",
    "lint:format": "bunx @biomejs/biome format --write",
    "lint:md": "bunx prettier --write \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "lint:md:check": "bunx prettier --check \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "lint:package": "bunx syncpack format",
    "lint:types": "tsc --noEmit",
    "prepare": "husky",
    "skills:link:project": "bun $HOME/.claude/skills/knowledgeislands-bootstrap/scripts/link-skills.ts",
    "site:clean": "rm -rf dist .wrangler",
    "site:deploy": "bunx wrangler deploy",
    "site:preview": "bun run build && bunx wrangler dev"
  },
  "type": "module"
}
