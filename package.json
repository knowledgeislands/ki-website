{
  "name": "arcadia-website",
  "description": "The public facing portal of Arcadia, designed to share knowledge outward and provide access to key resources from the principal island",
  "version": "1.0.0",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/utils": "^8.58.1",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.3",
    "eslint-config-love": "^151.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "json5": "^2.2.3",
    "lucide": "^0",
    "markdownlint-cli2": "^0.17.2",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.3",
    "syncpack": "^14.3.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "private": true,
  "scripts": {
    "build": "node --import tsx/esm node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts",
    "clean": "rm -rf dist node_modules",
    "dev": "concurrently --names css,11ty --prefix-colors cyan,yellow \"npm run dev:css\" \"npm run dev:serve\"",
    "dev:css": "npx tailwindcss -i src/assets/css/main.css -o dist/assets/css/main.css --watch",
    "dev:serve": "node --import tsx/esm node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts --serve --port 3000",
    "lint:code": "npx eslint .",
    "lint:deps:missing": "npx depcheck --json | npx node-jq --sort-keys '.' | npx node-jq '.missing | keys | .[]' | xargs npm add -D",
    "lint:deps:unused": "npx depcheck --json | npx node-jq --sort-keys '.' | npx node-jq '.devDependencies[]' | xargs npm uninstall",
    "lint:md": "npx prettier --write \"**/*.md\" --ignore-path .gitignore && npx markdownlint-cli2",
    "lint:package": "npx syncpack format",
    "lint:types": "npx tsc --noEmit",
    "update:libs": "npx ncu"
  },
  "type": "module"
}
