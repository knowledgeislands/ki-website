{
  "name": "arcadia-website",
  "description": "The public facing portal of Arcadia, designed to share knowledge outward and provide access to key resources from the principal island",
  "version": "1.0.0",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/utils": "^8.59.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-config-love": "^153.0.0",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "json5": "^2.2.3",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "syncpack": "^14.3.0",
    "typescript": "^6.0.3"
  },
  "private": true,
  "scripts": {
    "build": "node --experimental-strip-types node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts",
    "clean": "rm -rf dist node_modules package.lock.json",
    "dev": "concurrently --names css,11ty --prefix-colors cyan,yellow \"npm run dev:css\" \"npm run dev:serve\"",
    "dev:css": "npx tailwindcss -i src/assets/css/main.css -o dist/assets/css/main.css --watch",
    "dev:serve": "node --experimental-strip-types node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts --serve --port 3000",
    "lint:code": "npx eslint .",
    "lint:deps:missing": "npx depcheck --json | npx node-jq --sort-keys '.' | npx node-jq '.missing | keys | .[]' | xargs npm add -D",
    "lint:deps:unused": "npx depcheck --json | npx node-jq --sort-keys '.' | npx node-jq '.devDependencies[]' | xargs npm uninstall",
    "lint:md": "npx prettier --write \"**/*.md\" --ignore-path .gitignore && npx markdownlint-cli2",
    "lint:package": "npx syncpack format",
    "lint:types": "npx tsc --noEmit",
    "update:libs": "npx npm-check-updates"
  },
  "type": "module"
}
