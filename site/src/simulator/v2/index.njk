<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>{{ title }}</title><script src="/assets/js/d3.min.js"></script><style>
  :root{color-scheme:dark;font-family:Inter,system-ui,sans-serif;background:#080a12;color:#e9eaff}*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at 58% 35%,#17153a 0,#080a12 50%);min-height:100vh}.app{max-width:1500px;margin:auto;padding:20px}.top{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #2d2a48;padding:8px 0 18px}.top a{color:#b8b4dc;text-decoration:none}.tag{color:#8d7cff;font-size:11px;letter-spacing:.14em;text-transform:uppercase}.layout{display:grid;grid-template-columns:280px 1fr;gap:18px;margin-top:18px}.panel{background:rgb(20 22 36 / .86);border:1px solid #302d4c;border-radius:14px;padding:18px;box-shadow:0 18px 50px #0005}.panel h2{font-size:14px;letter-spacing:.1em;text-transform:uppercase;margin:0 0 8px;color:#beb8ee}.control{border-top:1px solid #2c2942;padding:15px 0}.control:first-of-type{border:0}.control label{display:flex;justify-content:space-between;font-size:13px;font-weight:650}.control output{color:#54ebe1;font-variant-numeric:tabular-nums}.control small{display:block;color:#9c9ab2;font-size:11px;line-height:1.4;margin-top:5px}.control input{accent-color:#8d7cff;width:100%}.control-scale{display:flex;justify-content:space-between;color:#747289;font:9px/1 ui-monospace,SFMono-Regular,monospace;margin-top:1px}.stage{min-width:0}.chart-panel{padding:20px}.chart-head{display:flex;justify-content:space-between;gap:12px;align-items:end}.chart-head h1{font-size:clamp(1.25rem,3vw,2rem);margin:3px 0}.chart-head p{color:#a8a5c2;font-size:12px;margin:0;max-width:42ch}.chart{display:block;width:100%;margin-top:16px}.axis text{fill:#8e8ca7;font-size:11px}.axis line,.axis path{stroke:#45415e}.grid line{stroke:#24233a}.readouts{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-top:14px}.metric{background:#0c0e19;border:1px solid #2c2944;border-radius:8px;padding:10px}.metric b{display:block;color:#68eee6;font-size:18px;font-variant-numeric:tabular-nums}.metric span{color:#9d9ab2;font-size:10px;letter-spacing:.08em;text-transform:uppercase}@media(max-width:800px){.layout{grid-template-columns:1fr}.readouts{grid-template-columns:repeat(2,1fr)}}
.range-wrap{position:relative}.slider-ticks{display:grid;grid-template-columns:repeat(5,1fr);height:6px;margin:-1px 0 1px;pointer-events:none}.slider-ticks span{align-self:start;justify-self:center;width:1px;height:4px;background:#5b5871}.slider-ticks .mid{height:6px;background:#b2afc7}.control-value{display:inline-flex;align-items:center;gap:5px}.reset-control{appearance:none;padding:0;border:0;background:transparent;color:#8d8aa5;font:15px/1 ui-monospace,SFMono-Regular,monospace;cursor:pointer}.reset-control:hover,.reset-control:focus-visible{color:#fff}.reset{width:100%;margin-top:14px;padding:9px 12px;background:#17172a;color:#c7c4e8;border:1px solid #4b476b;border-radius:7px;font:600 11px Inter,system-ui,sans-serif;letter-spacing:.08em;text-transform:uppercase;cursor:pointer}.reset:hover{background:#24213d;color:#fff}
.model-spec{font-size:11px;line-height:1.55;color:#aaa7be}.model-spec h3{color:#e9eaff;font-size:12px;margin:18px 0 6px}.model-spec code{display:block;background:#0b0d18;border:1px solid #292640;border-radius:7px;color:#b9b3f7;font:10px/1.65 ui-monospace,SFMono-Regular,monospace;margin:7px 0;padding:9px}.model-spec ul{margin:7px 0;padding-left:17px}.chart-context{max-width:42ch}.chart-head .chart-context p{max-width:none}.chart-legend{display:flex;flex-wrap:wrap;gap:4px 16px;margin-top:10px}.signal{display:flex;align-items:center;gap:7px;color:#aaa7be;font-size:11px}.signal i{display:block;width:18px;height:2px;background:#58eee2}.signal.high-low i{background:#a591ff}@media(min-width:1200px){.app{max-width:1700px}.layout{grid-template-columns:270px minmax(0,1fr) 310px}}@media(max-width:1199px) and (min-width:801px){.model-spec{grid-column:1/-1}}
</style></head><body><main class="app"><header class="top"><div><div class="tag">Knowledge Islands / Simulator V2</div><strong>Capability amplification calibration</strong></div><a href="/simulator/">Exit to versions ↗</a></header><div class="layout"><aside class="panel"><h2>Conditions</h2><p style="color:#a8a5c2;font-size:12px;line-height:1.5">Human conditions centre at zero on a −100 to +100 scale. AI power is off at zero and amplifies rather than directs.</p><div id="controls"></div></aside><section class="stage"><div class="panel chart-panel"><div class="chart-head"><div><div class="tag">Fixed frame / 0—10 years</div><h1>Expected value & uncertainty</h1></div><div class="chart-context"><p>Axes never move. Only the trajectory, high/low bounds, cone and numerical signals respond to a changed condition.</p><div class="chart-legend" aria-label="Graph legend"><div class="signal"><i></i>Most likely outcome</div><div class="signal high-low"><i></i>High / low bounds</div></div></div></div><svg class="chart" viewBox="0 0 940 560" role="img" aria-label="Fixed ten-year expected-value chart with high and low uncertainty bounds"><g class="grid"></g><path id="cone" fill="#806cff" fill-opacity=".18"></path><path id="low-line" fill="none" stroke="#a591ff" stroke-width="2"></path><path id="high-line" fill="none" stroke="#a591ff" stroke-width="2"></path><path id="zero" stroke="#4b4768" stroke-width="1.5" stroke-dasharray="5 5"></path><path id="line" fill="none" stroke="#58eee2" stroke-width="4"></path><g class="axis y"></g><g class="axis x" transform="translate(0,500)"></g><text x="455" y="545" fill="#8e8ca7" font-size="11" text-anchor="middle">Years</text></svg><div class="readouts"><div class="metric"><span>Starting state</span><b id="start">0.0</b></div><div class="metric"><span>Human direction</span><b id="direction">0.00</b></div><div class="metric"><span>Downside protection</span><b id="precision">15%</b></div><div class="metric"><span>Year 10 AI multiplier</span><b id="amplification">1.00×</b></div><div class="metric"><span>Year 10 expected</span><b id="year10">0.0</b></div><div class="metric"><span>Year 10 range</span><b id="range">-58.2 — 58.2</b></div></div></div></section><aside class="panel model-spec" aria-labelledby="model-spec-title"><div class="tag">Calibration 0.6 / experimental</div><h2 id="model-spec-title">Model specification</h2><h3>Factor roles</h3><ul><li>Intelligence (i): stronger starting state and direction</li><li>Learning (l): stronger direction and signed growth rate</li><li>Skills (s): stronger direction and base precision</li><li>Governance (g): downside protection only</li><li>AI power (p): dominant compounding amplification and uncertainty</li></ul><h3>Input domains</h3><code>i,l,s,g = value / 100<br>values = −100…+100<br>p = AI power / 100<br>t = years, 0…10</code><h3>Derived signals</h3><code>S₀ = 12(.70i + .18l + .12s)<br>H = .55i + .40l + .30s<br>Q = clamp(.15 + .10i + .08l<br>&nbsp;&nbsp;+ .12s, .05, .95)<br>D = clamp(Q + .35g, .05, .95)<br>A(t) = (1 + .15p)^t<br>r = .06 + .03l<br>cₕ = .046 + .10(1−Q)<br>cₗ = .046 + .10(1−D)</code><h3>Trajectory</h3><code>F(t) = ((1+r)^t − 1)<br>&nbsp;&nbsp;/ ((1.06)^10 − 1)<br>E(t) = S₀ + 24HA(t)F(t)</code><h3>Uncertainty</h3><code>Rₕ(t) = 20(1−Q)(1+cₕ)^t<br>&nbsp;&nbsp;+ p(1−Q)(12 + 28(t/10)^1.35)<br>Rₗ(t) = 20(1−D)(1+cₗ)^t<br>&nbsp;&nbsp;+ p(1−D)(12 + 28(t/10)^1.35)<br>Low(t) = E(t) − Rₗ(t)<br>High(t) = E(t) + Rₕ(t)</code><p>Midpoint human conditions with AI off produce E = 0 and 15% downside protection. The bounds begin at ±17 and widen to about ±58.2 by year 10. Increasing governance lifts only the low bound; the expected and high outcomes stay fixed. Intelligence, learning and skills use deliberately stronger experimental coefficients so their curve effects are easier to inspect. AI remains dominant, compounding the trajectory to about 4.05× at year 10 when power is 100. The axes remain fixed at −120…+120.</p></aside></div></main><script>
const defs=[['intelligence','Raw intelligence',0,'Strongly sets starting state and direction.'],['learning','Learning ability',0,'Strengthens direction and the human growth rate.'],['skills','Skills & knowledge',0,'Adds applied direction and base precision.'],['governance','Governance & guard rails',0,'Protects against downside outcomes only.'],['power','AI power',0,'Compounds trajectory and increases uncertainty.']];
const host=document.querySelector('#controls');host.innerHTML=defs.map(([id,label,value,help])=>{const human=id!=='power',min=human?-100:0,scale=human?'<div class="control-scale" aria-hidden="true"><span>−100</span><span>0</span><span>+100</span></div>':'',ticks=human?'<div class="slider-ticks" aria-hidden="true"><span></span><span></span><span class="mid"></span><span></span><span></span></div>':'';return`<div class="control"><label for="${id}">${label}<span class="control-value"><button class="reset-control" type="button" data-reset="${id}" aria-label="Reset ${label} to zero">↺</button><output id="${id}-out">${value}</output></span></label><div class="range-wrap"><input id="${id}" type="range" min="${min}" max="100" value="${value}"></div>${ticks}${scale}<small>${help}</small></div>`}).join('')+'<button id="reset" class="reset" type="button">Reset all calibration</button>';
const x=d3.scaleLinear().domain([0,10]).range([70,900]),y=d3.scaleLinear().domain([-120,120]).range([500,35]),svg=d3.select('.chart');svg.select('.grid').call(d3.axisLeft(y).ticks(6).tickSize(-830).tickFormat(''));svg.select('.grid .domain').remove();svg.select('.y').attr('transform','translate(70,0)').call(d3.axisLeft(y).ticks(6));svg.select('.x').attr('transform','translate(0,500)').call(d3.axisBottom(x).ticks(5));svg.select('#zero').attr('d',`M70 ${y(0)}H900`);const line=d3.line().x(d=>x(d.t)).y(d=>y(d.e)).curve(d3.curveMonotoneX),lowLine=d3.line().x(d=>x(d.t)).y(d=>y(d.l)).curve(d3.curveMonotoneX),highLine=d3.line().x(d=>x(d.t)).y(d=>y(d.u)).curve(d3.curveMonotoneX),area=d3.area().x(d=>x(d.t)).y0(d=>y(d.l)).y1(d=>y(d.u)).curve(d3.curveMonotoneX);
function val(id){return +document.querySelector('#'+id).value}function n(id){return val(id)/100}function signed(v){return v>0?'+'+v:String(v)}function clamp(v){return Math.max(.05,Math.min(.95,v))}function calc(){const i=n('intelligence'),l=n('learning'),s=n('skills'),g=n('governance'),p=val('power')/100,S0=12*(.7*i+.18*l+.12*s),H=.55*i+.4*l+.3*s,Q=clamp(.15+.1*i+.08*l+.12*s),D=clamp(Q+.35*g),A=t=>Math.pow(1+.15*p,t),r=.06+.03*l,cHigh=.046+.1*(1-Q),cLow=.046+.1*(1-D),F=t=>(Math.pow(1+r,t)-1)/(Math.pow(1.06,10)-1),risk=(q,c,t)=>20*(1-q)*Math.pow(1+c,t)+p*(1-q)*(12+28*Math.pow(t/10,1.35)),data=d3.range(0,10.01,.25).map(t=>{const e=S0+24*H*A(t)*F(t);return{t,e,l:e-risk(D,cLow,t),u:e+risk(Q,cHigh,t)}});return{S0,H,Q,D,A10:A(10),data}}function render(){const m=calc(),last=m.data.at(-1),d=ms=>ms.toFixed(1);defs.forEach(([id])=>document.querySelector('#'+id+'-out').value=id==='power'?val(id):signed(val(id)));document.querySelector('#start').textContent=d(m.S0);document.querySelector('#direction').textContent=m.H.toFixed(2);document.querySelector('#precision').textContent=Math.round(m.D*100)+'%';document.querySelector('#amplification').textContent=m.A10.toFixed(2)+'×';document.querySelector('#year10').textContent=d(last.e);document.querySelector('#range').textContent=d(last.l)+' — '+d(last.u);const dur=matchMedia('(prefers-reduced-motion: reduce)').matches?0:260;svg.select('#cone').interrupt().transition().duration(dur).attr('d',area(m.data));svg.select('#low-line').interrupt().transition().duration(dur).attr('d',lowLine(m.data));svg.select('#high-line').interrupt().transition().duration(dur).attr('d',highLine(m.data));svg.select('#line').interrupt().transition().duration(dur).attr('d',line(m.data))}document.querySelectorAll('input').forEach(e=>e.addEventListener('input',render));document.querySelectorAll('.reset-control').forEach(button=>button.addEventListener('click',()=>{const [,,value]=defs.find(([id])=>id===button.dataset.reset);document.querySelector('#'+button.dataset.reset).value=value;render()}));document.querySelector('#reset').addEventListener('click',()=>{defs.forEach(([id,,value])=>document.querySelector('#'+id).value=value);render()});render();
</script></body></html>
