{#
  Knowledge Islands SVG icon macros.
  Each icon maps to the canonical KI symbol vocabulary (Symbol Library).
  Usage: {% from "macros/icons.njk" import kiIcon %}
         {{ kiIcon("lighthouse", 24) }}
  All icons: island, lighthouse, compass, tree, route, anchor, archipelago, harbour, stellar, book, weave
#}

{% macro kiIcon(name, size=20) %}
  {%- if name == "island" -%}
    {# Domain of knowledge #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="14" x2="12" y2="9"/>
      <path d="M12 9 L8.5 7 M12 9 L15.5 7 M12 9 L12 6"/>
      <path d="M5 14 Q8.5 10 12 10 Q15.5 10 19 14"/>
      <path d="M3 18 Q6 17 9 18 Q12 19 15 18 Q18 17 21 18"/>
    </svg>
  {%- elif name == "lighthouse" -%}
    {# Guidance / governance #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 20 L9.5 9 L14.5 9 L14 20"/>
      <line x1="7" y1="20" x2="17" y2="20"/>
      <rect x="10" y="6" width="4" height="3" rx="0.5"/>
      <path d="M14 7 L19 5 M14 7.5 L19 7.5 M14 8 L19 10"/>
    </svg>
  {%- elif name == "compass" -%}
    {# Cartographic structure / orientation (Conventions) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <line x1="12" y1="3" x2="12" y2="21"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <path d="M10 7 L12 4 L14 7"/>
    </svg>
  {%- elif name == "tree" -%}
    {# Ancient forest / wisdom / continuity (Activities) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="21" x2="12" y2="15"/>
      <path d="M5 15 L12 5 L19 15 Z"/>
      <path d="M7 15 L12 8 L17 15"/>
    </svg>
  {%- elif name == "route" -%}
    {# Relationship / collaboration / exchange (Agents) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="5" cy="12" r="2.5"/>
      <circle cx="19" cy="12" r="2.5"/>
      <path d="M7.5 12 C10 6 14 18 16.5 12"/>
    </svg>
  {%- elif name == "anchor" -%}
    {# Port / operational systems (Tools) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="6" r="2"/>
      <line x1="12" y1="8" x2="12" y2="20"/>
      <line x1="7" y1="11" x2="17" y2="11"/>
      <path d="M5.5 16.5 C5.5 20.5 12 21.5 12 20 C12 21.5 18.5 20.5 18.5 16.5"/>
    </svg>
  {%- elif name == "archipelago" -%}
    {# Federated knowledge ecosystem (Territory) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="5.5" cy="17" rx="3" ry="2"/>
      <ellipse cx="18.5" cy="17" rx="3" ry="2"/>
      <ellipse cx="12" cy="8" rx="3.5" ry="2"/>
      <path d="M7.5 15.5 L10 10 M14 10 L16.5 15.5"/>
    </svg>
  {%- elif name == "harbour" -%}
    {# Integration point (Harbour / Contribution Process) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="4" x2="12" y2="10"/>
      <line x1="9" y1="7" x2="15" y2="7"/>
      <rect x="6" y="10" width="12" height="3" rx="1"/>
      <line x1="9" y1="13" x2="9" y2="18"/>
      <line x1="15" y1="13" x2="15" y2="18"/>
      <path d="M3 18 Q6 17 9 18 Q12 19 15 18 Q18 17 21 18"/>
    </svg>
  {%- elif name == "stellar" -%}
    {# Celestial guide / long-range orientation (AI agents) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="2.5"/>
      <line x1="12" y1="3" x2="12" y2="9"/>
      <line x1="12" y1="15" x2="12" y2="21"/>
      <line x1="3" y1="12" x2="9" y2="12"/>
      <line x1="15" y1="12" x2="21" y2="12"/>
      <line x1="5.5" y1="5.5" x2="8.5" y2="8.5"/>
      <line x1="15.5" y1="15.5" x2="18.5" y2="18.5"/>
      <line x1="18.5" y1="5.5" x2="15.5" y2="8.5"/>
      <line x1="8.5" y1="15.5" x2="5.5" y2="18.5"/>
    </svg>
  {%- elif name == "book" -%}
    {# Knowledge store / editor (Obsidian) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 4 L4 20 L20 20 L20 4 Z"/>
      <line x1="12" y1="4" x2="12" y2="20"/>
      <line x1="8" y1="9" x2="11" y2="9"/>
      <line x1="8" y1="13" x2="11" y2="13"/>
    </svg>
  {%- elif name == "weave" -%}
    {# Cross-domain synthesis (ChatGPT / secondary AI) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="12" r="5"/>
      <circle cx="15" cy="12" r="5"/>
    </svg>
  {%- elif name == "grid" -%}
    {# Structure / project management (Linear) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1"/>
      <rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/>
      <rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
  {%- elif name == "current" -%}
    {# Information flow / communication (M365) #}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 8 Q7 4 12 8 Q17 12 21 8"/>
      <path d="M3 14 Q7 10 12 14 Q17 18 21 14"/>
      <path d="M3 20 Q7 16 12 20 Q17 24 21 20"/>
    </svg>
  {%- endif -%}
{% endmacro %}
