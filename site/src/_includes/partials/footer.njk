<footer style="background-color: var(--color-navy); border-top: 1px solid rgb(255 255 255 / 8%); padding: 3rem 0;">
  <div class="page-container">
    <div class="grid-3col" style="gap: 2rem; margin-bottom: 2.5rem;">

      <div>
        <p style="font-family: var(--font-heading); font-size: 1rem; color: var(--color-parchment); margin-bottom: 0.5rem;">Knowledge Islands</p>
        <p style="font-size: 0.875rem; color: rgb(245 239 224 / 65%); line-height: 1.6;">
          A model for building, governing, and evolving knowledge across individuals, teams, and generations.
        </p>
      </div>

      <div>
        <p style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgb(245 239 224 / 45%); margin-bottom: 0.75rem;">Explore</p>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {% for item in site.nav %}
            <li>
              <a href="{{ item.href }}" style="font-size: 0.875rem; color: rgb(245 239 224 / 70%); text-decoration: none;"
                onmouseover="this.style.color='var(--color-parchment)'" onmouseout="this.style.color='rgb(245 239 224 / 70%)'">
                {{ item.label }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div>
        <p style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgb(245 239 224 / 45%); margin-bottom: 0.75rem;">The Model</p>
        <p style="font-size: 0.875rem; color: rgb(245 239 224 / 65%); line-height: 1.6;">
          Conventions · Processes · Activities · Agents · Tools
        </p>
      </div>

    </div>

    <div style="border-top: 1px solid rgb(255 255 255 / 10%); padding-top: 1.5rem; display: flex; align-items: center; justify-content: space-between;">
      <p style="font-size: 0.8125rem; color: rgb(245 239 224 / 40%); margin: 0;">
        © {{ site.title }}
      </p>
      <p style="font-size: 0.8125rem; color: rgb(245 239 224 / 40%); margin: 0; font-style: italic;">
        Knowledge as a civilisation question.
      </p>
    </div>
  </div>
</footer>
